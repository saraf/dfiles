#!/bin/bash

set -o pipefail

# ==========================================================
# Configuration
# ==========================================================

REMOTE="dropbox:ZimBackups"
NOTEBOOK="$HOME/ZimNotes"
RESTORE_DIR="/tmp/zim_restore"

GREEN='\033[1;32m'
YELLOW='\033[1;33m'
RED='\033[1;31m'
NC='\033[0m'

cleanup() {
    rm -rf "$RESTORE_DIR" 2>/dev/null
}

trap 'echo; echo "Restore cancelled."; cleanup; exit 130' INT
trap cleanup EXIT

# ==========================================================
# Functions
# ==========================================================

check_prerequisites() {

    for cmd in rclone fzf tar zstd; do
        if ! command -v "$cmd" >/dev/null 2>&1; then
            echo
            echo "Error: required command '$cmd' not found."
            echo "Install with: sudo apt install $cmd"
            exit 1
        fi
    done

}

list_backups() {

    rclone lsf "$REMOTE" \
        | grep '\.tar\.zst$' \
        | sort -r

}

select_backup() {

    BACKUP=$(list_backups | fzf --prompt="Select backup to restore: ")

    STATUS=$?

    if [[ $STATUS -ne 0 ]]; then
        echo
        echo "Selection cancelled."
        exit 0
    fi

    if [[ -z "$BACKUP" ]]; then
        echo
        echo "No backup selected."
        exit 0
    fi

    echo "$BACKUP"

}

download_backup() {

    BACKUP="$1"

    mkdir -p "$RESTORE_DIR"

    echo
    echo -e "${YELLOW}Downloading backup...${NC}"

    if ! rclone copy "$REMOTE/$BACKUP" "$RESTORE_DIR"; then
        echo -e "${RED}Download failed.${NC}"
        exit 1
    fi

}

extract_backup() {

    BACKUP="$1"

    echo
    echo -e "${YELLOW}Extracting archive...${NC}"

    if ! tar -I zstd -xf "$RESTORE_DIR/$BACKUP" -C "$RESTORE_DIR"; then
        echo -e "${RED}Extraction failed.${NC}"
        exit 1
    fi

}

confirm_restore() {

    echo
    echo -e "${RED}This will overwrite:${NC}"
    echo "  $NOTEBOOK"
    echo
    read -p "Continue? (y/N): " ans

    [[ "$ans" == "y" || "$ans" == "Y" ]]

}

perform_restore() {

    TIMESTAMP=$(date +%Y-%m-%d_%H-%M-%S)
    SAFETY_COPY="$NOTEBOOK.pre-restore-$TIMESTAMP"

    echo
    echo -e "${YELLOW}Preserving current notebook:${NC}"
    echo "  $SAFETY_COPY"

    if [[ -d "$NOTEBOOK" ]]; then
        mv "$NOTEBOOK" "$SAFETY_COPY"
    fi

    echo
    echo -e "${YELLOW}Restoring notebook...${NC}"

    mv "$RESTORE_DIR/ZimNotes" "$NOTEBOOK"

}


cleanup() {

    rm -rf "$RESTORE_DIR"

}

check_zim_not_running() {

    if pgrep -x zim >/dev/null; then
        echo
        echo -e "${RED}Error: Zim is currently running.${NC}"
        echo
        echo "Please close Zim before restoring the notebook."
        echo
        echo "You can verify with:"
        echo "  pgrep -a zim"
        echo
        exit 1
    fi

}

# ==========================================================
# Main
# ==========================================================

echo
echo "=============================="
echo "        ZIM RESTORE TOOL"
echo "=============================="
echo

check_prerequisites
check_zim_not_running

BACKUP=$(select_backup)

echo
echo -e "${GREEN}Selected backup:${NC} $BACKUP"

download_backup "$BACKUP"

extract_backup "$BACKUP"

if confirm_restore; then
    perform_restore
    cleanup

    echo
    echo -e "${GREEN}Notebook restored successfully.${NC}"
else
    echo
    echo "Restore cancelled."
fi
