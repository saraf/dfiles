#!/bin/bash

set -o pipefail

# ==========================================================
# zim-backup
# ==========================================================
#
# Create a compressed snapshot backup of the Zim notebook.
#
# Features
# --------
#
# • Archives the notebook using Zstandard compression
# • Excludes the `.zim/` metadata directory
# • Uploads backups to Dropbox via rclone
# • Automatically prunes older backups (keeps last N)
# • Supports local-only backups
#
# Backup naming format:
#
#   zim-YYYY-MM-DD_HH-MM-SS.tar.zst
#
# Examples:
#
#   zim-2026-03-09_23-52-48.tar.zst
#
# Usage
# -----
#
#   zim-backup
#       Create backup and upload to Dropbox
#
#   zim-backup --local-only
#       Create backup locally only (stored in ~/ZimBackups)
#
#   zim-backup --help
#
# First-time setup
# ----------------
#
# Ensure rclone is configured with a Dropbox remote:
#
#   rclone config
#
# ==========================================================


# ==========================================================
# Configuration
# ==========================================================

NOTEBOOK="$HOME/ZimNotes"
REMOTE="dropbox:ZimBackups"

LOCAL_BACKUP_DIR="$HOME/ZimBackups"
TMPDIR="/tmp/zim_backup"

KEEP_BACKUPS=20

TIMESTAMP=$(date +%Y-%m-%d_%H-%M-%S)
ARCHIVE="zim-$TIMESTAMP.tar.zst"

GREEN='\033[1;32m'
YELLOW='\033[1;33m'
RED='\033[1;31m'
NC='\033[0m'

LOCAL_ONLY=false


# ==========================================================
# Functions
# ==========================================================

show_help() {

cat << EOF

zim-backup
----------

Create a compressed snapshot backup of the Zim notebook.

Backups are compressed with zstd and stored with timestamps:

  zim-YYYY-MM-DD_HH-MM-SS.tar.zst

Usage:

  zim-backup
      Create backup and upload to Dropbox

  zim-backup --local-only
      Create backup locally only (stored in ~/ZimBackups)

  zim-backup --help

The .zim directory is excluded because it contains temporary
metadata (SQLite indexes) that Zim rebuilds automatically.

EOF

}


check_prerequisites() {

    for cmd in rclone tar zstd; do
        if ! command -v "$cmd" >/dev/null 2>&1; then
            echo
            echo "Error: required command '$cmd' not found."
            echo
            echo "Install it with:"
            echo "  sudo apt install $cmd"
            echo
            exit 1
        fi
    done

}


check_remote() {

    if ! rclone listremotes | grep -q "^${REMOTE%%:*}:"; then
        echo
        echo "Error: rclone remote '${REMOTE%%:*}' is not configured."
        echo
        echo "Run:"
        echo "  rclone config"
        echo
        exit 1
    fi

}


check_online() {

    rclone about "${REMOTE%%:*}:" &>/dev/null

}


create_archive() {

    echo -e "${YELLOW}Creating compressed archive...${NC}"

    mkdir -p "$TMPDIR"

    tar \
        --exclude='.zim/**' \
        -I 'zstd -19' \
        -cf "$TMPDIR/$ARCHIVE" \
        -C "$HOME" "$(basename "$NOTEBOOK")"

    STATUS=$?

    if [[ $STATUS -ne 0 ]]; then
        echo -e "${RED}Backup creation failed.${NC}"
        exit 1
    fi

    echo -e "${GREEN}Archive created:${NC}"
    ls -lh "$TMPDIR/$ARCHIVE"

}


upload_backup() {

    echo
    echo -e "${YELLOW}Uploading backup to Dropbox...${NC}"

    rclone mkdir "$REMOTE"

    rclone copy "$TMPDIR/$ARCHIVE" "$REMOTE" \
        --log-level INFO

    STATUS=$?

    if [[ $STATUS -ne 0 ]]; then
        echo -e "${RED}Upload failed.${NC}"
        exit 1
    fi

    echo -e "${GREEN}Upload complete.${NC}"

}


prune_old_backups() {

    echo
    echo -e "${YELLOW}Pruning old backups (keeping last $KEEP_BACKUPS)...${NC}"

    rclone lsf "$REMOTE" \
        | grep '^zim-' \
        | sort -r \
        | tail -n +$((KEEP_BACKUPS+1)) \
        | while read -r old; do
            echo "Deleting $old"
            rclone deletefile "$REMOTE/$old"
        done

}


store_local_backup() {

    mkdir -p "$LOCAL_BACKUP_DIR"

    mv "$TMPDIR/$ARCHIVE" "$LOCAL_BACKUP_DIR/"

    echo
    echo -e "${GREEN}Local backup stored:${NC}"
    echo "  $LOCAL_BACKUP_DIR/$ARCHIVE"

}


cleanup_tmp() {

    rm -f "$TMPDIR/$ARCHIVE" 2>/dev/null

}


# ==========================================================
# Argument parsing
# ==========================================================

if [[ "$1" == "--help" || "$1" == "-h" || "$1" == "help" ]]; then
    show_help
    exit 0
fi

if [[ "$1" == "--local-only" ]]; then
    LOCAL_ONLY=true
fi


# ==========================================================
# Main program
# ==========================================================

echo
echo "=============================="
echo "        ZIM BACKUP TOOL"
echo "=============================="
echo

check_prerequisites

create_archive

if $LOCAL_ONLY; then
    echo
    echo -e "${YELLOW}Local-only mode enabled.${NC}"
    store_local_backup
    exit 0
fi


check_remote

echo
echo -e "${YELLOW}Checking Dropbox connectivity...${NC}"

if check_online; then

    echo -e "${GREEN}Dropbox reachable.${NC}"

    upload_backup
    prune_old_backups

else

    echo -e "${RED}Dropbox unreachable — storing backup locally.${NC}"

    store_local_backup
    exit 1

fi


cleanup_tmp

echo
echo -e "${GREEN}Backup finished successfully.${NC}"
echo
