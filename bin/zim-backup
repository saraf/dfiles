#!/bin/bash

NOTEBOOK="$HOME/ZimNotes/zim"
TMPDIR="/tmp/zim_backup"
DATE=$(date +%Y-%m-%d)
ARCHIVE="zim-$DATE.tar.zst"
REMOTE="dropbox:ZimBackups"

GREEN='\033[1;32m'
YELLOW='\033[1;33m'
RED='\033[1;31m'
NC='\033[0m'

echo
echo "=============================="
echo "        ZIM BACKUP TOOL"
echo "=============================="
echo

# Check if zstd exists
if ! command -v zstd >/dev/null 2>&1; then
    echo -e "${RED}Error: zstd is not installed.${NC}"
    echo
    echo "This script requires the Zstandard compressor."
    echo
    echo "Install it with:"
    echo
    echo "    sudo apt install zstd"
    echo
    exit 1
fi

mkdir -p "$TMPDIR"

echo -e "${YELLOW}Creating compressed archive...${NC}"

tar \
  --exclude='.zim/index.db' \
  -I 'zstd -19' \
  -cf "$TMPDIR/$ARCHIVE" \
  -C "$HOME" ZimNotes

if [ $? -ne 0 ]; then
    echo -e "${RED}Backup creation failed.${NC}"
    exit 1
fi

echo -e "${GREEN}Archive created:${NC}"
ls -lh "$TMPDIR/$ARCHIVE"

echo
echo -e "${YELLOW}Uploading to Dropbox...${NC}"

rclone copy "$TMPDIR/$ARCHIVE" "$REMOTE"

if [ $? -ne 0 ]; then
    echo -e "${RED}Upload failed.${NC}"
    exit 1
fi

echo -e "${GREEN}Upload complete.${NC}"

rm "$TMPDIR/$ARCHIVE"

echo -e "${GREEN}Temporary archive removed.${NC}"
echo
echo -e "${GREEN}Backup finished successfully.${NC}"
echo
