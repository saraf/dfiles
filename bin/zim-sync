#!/bin/bash
#
show_help() {
cat << 'EOF'
# zim-sync
# --------
# Launch Zim with automatic Dropbox synchronization using rclone bisync.
#
# Workflow
# --------
# 1. Check whether Dropbox is reachable
# 2. If online, synchronize the notebook with Dropbox
# 3. Launch Zim
# 4. When Zim exits, synchronize changes back to Dropbox
#
# The entire `.zim/` directory is excluded because it contains temporary
# metadata (SQLite indexes) that Zim automatically rebuilds.
#
# Usage:
#
#   zim-sync
#   zim-sync --help
#
EOF
}

if [[ "$1" == "--help" || "$1" == "-h" || "$1" == "help" ]]; then
    show_help
    exit 0
fi


LOCKFILE="/tmp/zim-sync.lock"

exec 200>"$LOCKFILE"

if ! flock -n 200; then
    OTHER_PID=$(cat "$LOCKFILE" 2>/dev/null)

    echo
    echo "Another zim-sync process is already running (PID $OTHER_PID)."
    echo

    if [[ -n "$OTHER_PID" ]]; then
        echo "Inspect it with:"
        echo "  ps -fp $OTHER_PID"
        echo
        echo "If it is stuck you may terminate it with:"
        echo "  kill $OTHER_PID"
    fi

    echo
    exit 1
fi

# record our PID
echo $$ >&200

cleanup() {
    flock -u 200
}

trap cleanup EXIT


NOTEBOOK="$HOME/ZimNotes"
REMOTE="dropbox:daily notes 3 from may 2k21/zim"

GREEN='\033[1;32m'
YELLOW='\033[1;33m'
RED='\033[1;31m'
NC='\033[0m'

echo
echo "============================="
echo "        ZIM SYNC TOOL"
echo "============================="
echo


check_online() {
    rclone about dropbox: &>/dev/null
}


bisync_initialized() {
    rclone bisync "$REMOTE" "$NOTEBOOK" \
        --check-access \
        --exclude ".zim/**" \
        --dry-run &>/dev/null
}


run_bisync() {

    if bisync_initialized; then

        echo -e "${GREEN}Running bisync...${NC}"

        rclone bisync "$REMOTE" "$NOTEBOOK" \
            --exclude ".zim/**" \
            --resilient \
            --fast-list \
            --checkers 12 \
            --transfers 6 \
            --size-only \
            --dropbox-batch-mode async \
            --progress

    else

        echo -e "${YELLOW}First run detected — initializing bisync state...${NC}"

        rclone bisync "$REMOTE" "$NOTEBOOK" \
            --resync \
            --exclude ".zim/**" \
            --resilient \
            --fast-list \
            --checkers 12 \
            --transfers 6 \
            --size-only \
            --dropbox-batch-mode async \
            --progress
    fi
}


echo -e "${YELLOW}Checking Dropbox connectivity...${NC}"

if check_online; then
    echo -e "${GREEN}Dropbox reachable.${NC}"
    run_bisync
else
    echo -e "${YELLOW}Offline mode detected. Skipping sync.${NC}"
fi

echo
echo -e "${GREEN}Starting Zim...${NC}"

zim "$NOTEBOOK"

echo
echo -e "${YELLOW}Zim closed.${NC}"
echo -e "${YELLOW}Checking connectivity again...${NC}"

if check_online; then
    run_bisync
else
    echo -e "${RED}Still offline. Changes remain local.${NC}"
fi

echo
echo -e "${GREEN}Done.${NC}"
