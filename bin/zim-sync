#!/bin/bash

set -o pipefail

# ==========================================================
# Configuration
# ==========================================================

NOTEBOOK="$HOME/ZimNotes"
REMOTE="dropbox:daily notes 3 from may 2k21/zim"
LOCKFILE="/tmp/zim-sync.lock"

GREEN='\033[1;32m'
YELLOW='\033[1;33m'
RED='\033[1;31m'
NC='\033[0m'


# ==========================================================
# Functions
# ==========================================================

show_help() {

cat << EOF

zim-sync
--------

Launch Zim with automatic Dropbox synchronization using rclone bisync.

Workflow
--------

1. Sync notebook with Dropbox
2. Launch Zim
3. Sync again after Zim exits

If offline, syncing is skipped and Zim runs normally.

First-time setup
----------------

Run once manually:

  rclone bisync "$REMOTE" "$NOTEBOOK" --resync

Usage
-----

  zim-sync
  zim-sync --help

EOF

}


check_prerequisites() {

    for cmd in rclone zim flock; do
        if ! command -v "$cmd" >/dev/null 2>&1; then
            echo
            echo "Error: required command '$cmd' not found."
            echo
            echo "Install it with:"
            echo "  sudo apt install $cmd"
            echo
            exit 1
        fi
    done

}


check_online() {

    rclone about "${REMOTE%%:*}:" &>/dev/null

}


run_bisync() {

    echo -e "${YELLOW}Running bisync...${NC}"

    rclone bisync "$REMOTE" "$NOTEBOOK" \
        --exclude ".zim/**" \
        --resilient \
        --fast-list \
        --checkers 8 \
        --transfers 4 \
        --size-only \
        --dropbox-batch-mode async \
        --no-update-modtime \
        --log-level INFO

    STATUS=$?

    if [[ $STATUS -ne 0 ]]; then
        echo
        echo "Bisync failed."
        echo
        echo "If this is the first run, initialize with:"
        echo "  rclone bisync \"$REMOTE\" \"$NOTEBOOK\" --resync"
        echo
        return 1
    fi

    echo -e "${GREEN}✓ Notebook synchronized.${NC}"
}


# ==========================================================
# Argument parsing
# ==========================================================

if [[ "$1" == "--help" || "$1" == "-h" || "$1" == "help" ]]; then
    show_help
    exit 0
fi


# ==========================================================
# Main program
# ==========================================================

echo
echo "============================="
echo "        ZIM SYNC TOOL"
echo "============================="
echo

check_prerequisites


# ----------------------------------------------------------
# Lock protection
# ----------------------------------------------------------

exec 200>"$LOCKFILE"

if ! flock -n 200; then
    OTHER_PID=$(cat "$LOCKFILE" 2>/dev/null)

    echo
    echo "Another zim-sync process is already running (PID $OTHER_PID)."
    echo

    if [[ -n "$OTHER_PID" ]]; then
        echo "Inspect it with:"
        echo "  ps -fp $OTHER_PID"
        echo
        echo "Terminate if needed:"
        echo "  kill $OTHER_PID"
    fi

    echo
    exit 1
fi

echo $$ >&200

cleanup() {
    flock -u 200
}

trap cleanup EXIT


# ----------------------------------------------------------
# Initial synchronization
# ----------------------------------------------------------

echo -e "${YELLOW}Checking Dropbox connectivity...${NC}"

if check_online; then
    echo -e "${GREEN}Dropbox reachable.${NC}"

    if ! run_bisync; then
        echo
        echo -e "${RED}Bisync failed — not launching Zim to avoid editing an unsynced notebook.${NC}"
        exit 1
    fi

else
    echo -e "${YELLOW}Offline mode detected. Skipping sync.${NC}"
fi


# ----------------------------------------------------------
# Launch Zim
# ----------------------------------------------------------

echo
echo -e "${GREEN}Starting Zim...${NC}"

zim "$NOTEBOOK" 2>/dev/null


# ----------------------------------------------------------
# Sync after Zim closes
# ----------------------------------------------------------

echo
echo -e "${YELLOW}Zim closed.${NC}"
echo -e "${YELLOW}Checking connectivity again...${NC}"

if check_online; then
    run_bisync
else
    echo -e "${RED}Still offline. Changes remain local.${NC}"
fi


echo
echo -e "${GREEN}Done.${NC}"
